---
// ThinkingDiagram.astro - Three paradigms of LLM inference
//
// ============================================================
// EDITABLE CONTENT - labels, descriptions, and captions
// ============================================================

const header = "From Generation To Reasoning";
const footer = "In all three paradigms, the per-token computation is identical (one forward pass through the network). The difference is in scaffolding: which tokens are generated, what they attend to, and whether the model interacts with external tools between reasoning steps.";

// Panel 1: Autoregressive Generation
const panel1 = {
  title: "1. Autoregressive Generation",
  subtitle: "Each token gets one forward pass. No planning phase.",
  braceLabel: "All tokens are output without any seperation between reasoning and responsing.",
  boxLine1: "The compute budget is fixed by: Depth of the network \u00d7 Number of output tokens.",
  boxLine2: 'The model must "know" the answer from pre-training.',
};

// Panel 2: Extended Thinking
const panel2 = {
  title: "2. Extended Thinking \u2192 Response",
  subtitle: "Generate reasoning tokens first. Respond with those in context.",
  legendThinking: "thinking",
  legendResponse: "response",
  legendAttention: "attention",
  thinkingBraceLabel: "Thinking tokens (hidden from user)",
  responseBraceLabel: "Response",
  insightLine1: "Key mechanism: attention from response tokens back to thinking tokens",
  insightLine2: "Each thinking token is a forward pass that transforms the model's representation.",
  insightLine3: "Response tokens attend to this enriched context \u2192 higher quality output.",
};

// Panel 3: Interleaved Thinking
const panel3 = {
  title: "3. Interleaved Thinking",
  subtitle: "Think \u2192 Act \u2192 Observe \u2192 Think again. Reasoning adapts to new information.",
  legendThinking: "thinking",
  legendToolCall: "tool call",
  legendToolResult: "tool result",
  legendResponse: "response",
  blockLabels: ["Plan", "read file", "result", "Revise", "run test", "result", "Assess", "Respond"],
  externalLabel: "external",
  insightLine1: "Key difference: thinking tokens now attend to tool results from the environment",
  insightLine2: "\u03b8\u2083,\u03b8\u2084 reason about file contents returned by the first tool call.",
  insightLine3: "\u03b8\u2085 reasons about test results, and revises the plan if the test failed.",
  insightLine4: "The model no longer reasons only from information in the prompt.",
  insightLine5: "It discovers new information, reasons about it, and adapts - like a human engineer.",
};

// ============================================================
// LAYOUT - positions and wiring (rarely needs editing)
// ============================================================

// Panel 1 token positions
const p1TokenXs = [30, 78, 126, 174, 222, 270, 318, 366];

// Panel 2 token positions
const p2ThinkXs = [30, 74, 118, 162, 206, 250];
const p2RespXs = [300, 344, 388];

// Panel 3 block label positions
const p3BlockLabelXs = [46, 101, 139, 194, 249, 287, 325, 380];
---

<div class="thinking-diagram">
<p class="td-header">{header}</p>

<!-- Panel 1: Autoregressive Generation -->
<div class="td-panel">
<svg viewBox="0 0 440 185" xmlns="http://www.w3.org/2000/svg">
  <text x="220" y="20" text-anchor="middle" font-size="13" font-weight="700" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel1.title}</text>
  <text x="220" y="36" text-anchor="middle" font-size="9.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel1.subtitle}</text>
  <!-- Attention arcs to last token -->
  <path d="M 385 70 Q 217 40 49 70" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.2"/>
  <path d="M 385 70 Q 241 40 97 70" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.25"/>
  <path d="M 385 70 Q 265 40 145 70" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.3"/>
  <path d="M 385 70 Q 289 40 193 70" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.35"/>
  <path d="M 385 70 Q 313 40 241 70" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.38"/>
  <path d="M 385 70 Q 337 40 289 70" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.42"/>
  <path d="M 385 70 Q 361 56 337 70" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.45"/>
  <!-- 8 tokens -->
  {p1TokenXs.map((x, i) => (
    <g>
      <rect x={x} y="70" width="38" height="26" rx="4" fill="var(--td-std-fill)" stroke="var(--td-std-stroke)" stroke-width="1.2"/>
      <text x={x+19} y="84" text-anchor="middle" font-size="9" font-weight="600" fill="var(--text-color)" font-family="monospace">{`t${String.fromCharCode(0x2081+i)}`}</text>
    </g>
  ))}
  <!-- Brace -->
  <path d="M 30 102 Q 30 118 217 118 Q 404 118 404 102" fill="none" stroke="var(--text-fade)" stroke-width="1"/>
  <text x="217" y="132" text-anchor="middle" font-size="9" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel1.braceLabel}</text>
  <!-- Info box -->
  <rect x="30" y="142" width="380" height="32" rx="4" fill="var(--td-box-neutral-fill)" stroke="var(--text-fade)" stroke-width="0.8"/>
  <text x="220" y="155" text-anchor="middle" font-size="8.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel1.boxLine1}</text>
  <text x="220" y="167" text-anchor="middle" font-size="8.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel1.boxLine2}</text>
</svg>
</div>

<!-- Panel 2: Extended Thinking -->
<div class="td-panel">
<svg viewBox="0 0 440 210" xmlns="http://www.w3.org/2000/svg">
  <text x="220" y="20" text-anchor="middle" font-size="13" font-weight="700" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel2.title}</text>
  <text x="220" y="36" text-anchor="middle" font-size="9.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel2.subtitle}</text>
  <!-- Legend -->
  <rect x="30" y="48" width="10" height="10" rx="2" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="0.8"/>
  <text x="44" y="56" font-size="8" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel2.legendThinking}</text>
  <rect x="90" y="48" width="10" height="10" rx="2" fill="var(--td-resp-fill)" stroke="var(--td-resp-stroke)" stroke-width="0.8"/>
  <text x="104" y="56" font-size="8" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel2.legendResponse}</text>
  <line x1="158" y1="54" x2="178" y2="54" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.5"/>
  <text x="183" y="57" font-size="8" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel2.legendAttention}</text>
  <!-- Separator -->
  <line x1="287" y1="62" x2="287" y2="103" stroke="var(--td-separator)" stroke-width="1" stroke-dasharray="4,3"/>
  <!-- Attention arcs from r₁ back to thinking tokens -->
  <path d="M 318 75 Q 183 45 48 75" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.2"/>
  <path d="M 318 75 Q 205 45 92 75" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.22"/>
  <path d="M 318 75 Q 227 45 136 75" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.24"/>
  <path d="M 318 75 Q 249 45 180 75" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.26"/>
  <path d="M 318 75 Q 271 48 224 75" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.28"/>
  <path d="M 318 75 Q 293 60 268 75" fill="none" stroke="var(--td-arc-blue)" stroke-width="1" opacity="0.3"/>
  <!-- 6 thinking tokens -->
  {p2ThinkXs.map((x, i) => (
    <g>
      <rect x={x} y="75" width="36" height="26" rx="4" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="1.2"/>
      <text x={x+18} y="89" text-anchor="middle" font-size="9" font-weight="600" fill="var(--text-color)" font-family="monospace">{`\u03b8${String.fromCharCode(0x2081+i)}`}</text>
    </g>
  ))}
  <!-- 3 response tokens -->
  {p2RespXs.map((x, i) => (
    <g>
      <rect x={x} y="75" width="36" height="26" rx="4" fill="var(--td-resp-fill)" stroke="var(--td-resp-stroke)" stroke-width="1.2"/>
      <text x={x+18} y="89" text-anchor="middle" font-size="9" font-weight="600" fill="var(--text-color)" font-family="monospace">{`r${String.fromCharCode(0x2081+i)}`}</text>
    </g>
  ))}
  <!-- Braces -->
  <path d="M 30 107 Q 30 119 158 119 Q 286 119 286 107" fill="none" stroke="var(--td-think-stroke)" stroke-width="1"/>
  <text x="158" y="132" text-anchor="middle" font-size="9" fill="var(--td-think-text)" font-family="system-ui, sans-serif">{panel2.thinkingBraceLabel}</text>
  <path d="M 300 107 Q 300 119 362 119 Q 424 119 424 107" fill="none" stroke="var(--td-resp-stroke)" stroke-width="1"/>
  <text x="362" y="132" text-anchor="middle" font-size="9" fill="var(--td-resp-text)" font-family="system-ui, sans-serif">{panel2.responseBraceLabel}</text>
  <!-- Insight box -->
  <rect x="24" y="142" width="392" height="55" rx="4" fill="var(--td-box-green-fill)" stroke="var(--td-box-green-stroke)" stroke-width="0.8"/>
  <text x="220" y="157" text-anchor="middle" font-size="8.5" font-weight="600" fill="var(--td-think-text)" font-family="system-ui, sans-serif">{panel2.insightLine1}</text>
  <text x="220" y="171" text-anchor="middle" font-size="8.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel2.insightLine2}</text>
  <text x="220" y="185" text-anchor="middle" font-size="8.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel2.insightLine3}</text>
</svg>
</div>

<!-- Panel 3: Interleaved Thinking -->
<div class="td-panel">
<svg viewBox="0 0 440 250" xmlns="http://www.w3.org/2000/svg">
  <text x="220" y="20" text-anchor="middle" font-size="13" font-weight="700" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.title}</text>
  <text x="220" y="36" text-anchor="middle" font-size="9.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.subtitle}</text>
  <!-- Legend -->
  <rect x="14" y="48" width="10" height="10" rx="2" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="0.8"/>
  <text x="28" y="56" font-size="7.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.legendThinking}</text>
  <rect x="82" y="48" width="10" height="10" rx="2" fill="var(--td-tool-fill)" stroke="var(--td-tool-stroke)" stroke-width="0.8"/>
  <text x="96" y="56" font-size="7.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.legendToolCall}</text>
  <rect x="150" y="48" width="10" height="10" rx="2" fill="var(--td-result-fill)" stroke="var(--td-result-stroke)" stroke-width="0.8"/>
  <text x="164" y="56" font-size="7.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.legendToolResult}</text>
  <rect x="228" y="48" width="10" height="10" rx="2" fill="var(--td-resp-fill)" stroke="var(--td-resp-stroke)" stroke-width="0.8"/>
  <text x="242" y="56" font-size="7.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.legendResponse}</text>
  <!-- Block group backgrounds -->
  <rect x="11" y="87" width="70" height="30" rx="6" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="0.6" opacity="0.3"/>
  <rect x="83" y="87" width="36" height="30" rx="6" fill="var(--td-tool-fill)" stroke="var(--td-tool-stroke)" stroke-width="0.6" opacity="0.3"/>
  <rect x="121" y="87" width="36" height="30" rx="6" fill="var(--td-result-fill)" stroke="var(--td-result-stroke)" stroke-width="0.6" opacity="0.3" stroke-dasharray="3,2"/>
  <rect x="159" y="87" width="70" height="30" rx="6" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="0.6" opacity="0.3"/>
  <rect x="231" y="87" width="36" height="30" rx="6" fill="var(--td-tool-fill)" stroke="var(--td-tool-stroke)" stroke-width="0.6" opacity="0.3"/>
  <rect x="269" y="87" width="36" height="30" rx="6" fill="var(--td-result-fill)" stroke="var(--td-result-stroke)" stroke-width="0.6" opacity="0.3" stroke-dasharray="3,2"/>
  <rect x="307" y="87" width="36" height="30" rx="6" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="0.6" opacity="0.3"/>
  <rect x="345" y="87" width="70" height="30" rx="6" fill="var(--td-resp-fill)" stroke="var(--td-resp-stroke)" stroke-width="0.6" opacity="0.3"/>
  <!-- Attention arcs from θ₅ back -->
  <path d="M 325 87 Q 177 57 29 87" fill="none" stroke="var(--td-arc-green)" stroke-width="1" opacity="0.18"/>
  <path d="M 325 87 Q 194 57 63 87" fill="none" stroke="var(--td-arc-green)" stroke-width="1" opacity="0.18"/>
  <path d="M 325 87 Q 232 57 139 87" fill="none" stroke="var(--td-tool-stroke)" stroke-width="1" opacity="0.18"/>
  <path d="M 325 87 Q 251 57 177 87" fill="none" stroke="var(--td-arc-green)" stroke-width="1" opacity="0.18"/>
  <path d="M 325 87 Q 268 60 211 87" fill="none" stroke="var(--td-arc-green)" stroke-width="1" opacity="0.18"/>
  <path d="M 325 87 Q 306 74 287 87" fill="none" stroke="var(--td-tool-stroke)" stroke-width="1" opacity="0.18"/>
  <!-- Tokens: θ₁ θ₂ -->
  <rect x="14" y="90" width="30" height="24" rx="4" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="1.2"/>
  <text x="29" y="103" text-anchor="middle" font-size="8" font-weight="600" fill="var(--text-color)" font-family="monospace">θ₁</text>
  <rect x="48" y="90" width="30" height="24" rx="4" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="1.2"/>
  <text x="63" y="103" text-anchor="middle" font-size="8" font-weight="600" fill="var(--text-color)" font-family="monospace">θ₂</text>
  <!-- Tool call 1 -->
  <rect x="86" y="90" width="30" height="24" rx="4" fill="var(--td-tool-fill)" stroke="var(--td-tool-stroke)" stroke-width="1.2"/>
  <text x="101" y="104" text-anchor="middle" font-size="11" fill="var(--text-color)">⚙</text>
  <!-- Result 1 -->
  <rect x="124" y="90" width="30" height="24" rx="4" fill="var(--td-result-fill)" stroke="var(--td-result-stroke)" stroke-width="1.2"/>
  <text x="139" y="104" text-anchor="middle" font-size="11" fill="var(--text-color)">→</text>
  <!-- θ₃ θ₄ -->
  <rect x="162" y="90" width="30" height="24" rx="4" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="1.2"/>
  <text x="177" y="103" text-anchor="middle" font-size="8" font-weight="600" fill="var(--text-color)" font-family="monospace">θ₃</text>
  <rect x="196" y="90" width="30" height="24" rx="4" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="1.2"/>
  <text x="211" y="103" text-anchor="middle" font-size="8" font-weight="600" fill="var(--text-color)" font-family="monospace">θ₄</text>
  <!-- Tool call 2 -->
  <rect x="234" y="90" width="30" height="24" rx="4" fill="var(--td-tool-fill)" stroke="var(--td-tool-stroke)" stroke-width="1.2"/>
  <text x="249" y="104" text-anchor="middle" font-size="11" fill="var(--text-color)">⚙</text>
  <!-- Result 2 -->
  <rect x="272" y="90" width="30" height="24" rx="4" fill="var(--td-result-fill)" stroke="var(--td-result-stroke)" stroke-width="1.2"/>
  <text x="287" y="104" text-anchor="middle" font-size="11" fill="var(--text-color)">→</text>
  <!-- θ₅ -->
  <rect x="310" y="90" width="30" height="24" rx="4" fill="var(--td-think-fill)" stroke="var(--td-think-stroke)" stroke-width="1.2"/>
  <text x="325" y="103" text-anchor="middle" font-size="8" font-weight="600" fill="var(--text-color)" font-family="monospace">θ₅</text>
  <!-- r₁ r₂ -->
  <rect x="348" y="90" width="30" height="24" rx="4" fill="var(--td-resp-fill)" stroke="var(--td-resp-stroke)" stroke-width="1.2"/>
  <text x="363" y="103" text-anchor="middle" font-size="8" font-weight="600" fill="var(--text-color)" font-family="monospace">r₁</text>
  <rect x="382" y="90" width="30" height="24" rx="4" fill="var(--td-resp-fill)" stroke="var(--td-resp-stroke)" stroke-width="1.2"/>
  <text x="397" y="103" text-anchor="middle" font-size="8" font-weight="600" fill="var(--text-color)" font-family="monospace">r₂</text>
  <!-- Block labels -->
  {p3BlockLabelXs.map((x, i) => (
    <text x={x} y="128" text-anchor="middle" font-size="7.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.blockLabels[i]}</text>
  ))}
  <!-- External world indicators -->
  <line x1="139" y1="114" x2="139" y2="136" stroke="var(--td-result-stroke)" stroke-width="0.8" stroke-dasharray="2,2"/>
  <text x="139" y="145" text-anchor="middle" font-size="6.5" fill="var(--td-result-stroke)" font-family="system-ui, sans-serif" font-style="italic">{panel3.externalLabel}</text>
  <line x1="287" y1="114" x2="287" y2="136" stroke="var(--td-result-stroke)" stroke-width="0.8" stroke-dasharray="2,2"/>
  <text x="287" y="145" text-anchor="middle" font-size="6.5" fill="var(--td-result-stroke)" font-family="system-ui, sans-serif" font-style="italic">{panel3.externalLabel}</text>
  <!-- Insight box -->
  <rect x="14" y="155" width="412" height="82" rx="4" fill="var(--td-box-purple-fill)" stroke="var(--td-box-purple-stroke)" stroke-width="0.8"/>
  <text x="220" y="170" text-anchor="middle" font-size="8.5" font-weight="600" fill="var(--td-tool-text)" font-family="system-ui, sans-serif">{panel3.insightLine1}</text>
  <text x="220" y="185" text-anchor="middle" font-size="8.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.insightLine2}</text>
  <text x="220" y="198" text-anchor="middle" font-size="8.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.insightLine3}</text>
  <text x="220" y="215" text-anchor="middle" font-size="8.5" font-weight="600" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.insightLine4}</text>
  <text x="220" y="228" text-anchor="middle" font-size="8.5" fill="var(--text-color)" font-family="system-ui, sans-serif">{panel3.insightLine5}</text>
</svg>
</div>

<p class="td-footer">{footer}</p>
</div>

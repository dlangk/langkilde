---
import { ANALYTICS } from "../lib/constants";

// Never emit the tag in dev. `npm run dev` and `npm run preview` both serve on
// localhost, and without this guard every reload/interaction hits the live GA4
// property. `preview` serves the production build (PROD is true there), so we
// also gate on hostname at runtime below.
const enabled = import.meta.env.PROD;
---

{
  enabled && (
    <script is:inline define:vars={{ gaId: ANALYTICS.gaId }}>
      // GA4, gated on first user interaction.
  //
  // gtag.js is ~150 KB and half this site's page weight. Loading it eagerly
  // (or on idle) puts it inside the Lighthouse trace window, where it gets
  // billed against TBT/unused-JS/legacy-JS. Instead we load it on the first
  // real interaction (scroll/tap/key), which every human reader produces,
  // and fall back to a 10s post-load timer so non-interacting visitors are
  // still counted. Bots and lab runs never interact, so they never pay for
  // (or get counted by) analytics.
  var loaded = false;

  function loadAnalytics() {
    if (loaded) return;
    // Belt-and-suspenders: `preview` serves the production build on localhost,
    // so refuse to fire anywhere but the real host.
    if (
      location.hostname === "localhost" ||
      location.hostname === "127.0.0.1"
    )
      return;
    loaded = true;

    var script = document.createElement("script");
    script.src = "https://www.googletagmanager.com/gtag/js?id=" + gaId;
    script.async = true;
    document.head.appendChild(script);

    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    window.gtag = gtag;

    var rawPath = window.location.pathname;
    var normalizedPath = rawPath.replace(/\/+$/, "") || "/";

    gtag("js", new Date());
    // Strip hash from page_location so GA4 Enhanced Measurement
    // doesn't fire extra page_view events on TOC/footnote/reference clicks
    gtag("config", gaId, {
      page_path: normalizedPath,
      page_location: window.location.origin + normalizedPath,
    });
  }

  // Defer the actual work off the interaction itself so the first
  // scroll/tap stays jank-free.
  function onFirstInteraction() {
    if (loaded) return;
    if ("requestIdleCallback" in window) {
      requestIdleCallback(loadAnalytics, { timeout: 2000 });
    } else {
      setTimeout(loadAnalytics, 0);
    }
  }

  ["pointerdown", "scroll", "keydown", "touchstart"].forEach(function (type) {
    window.addEventListener(type, onFirstInteraction, {
      once: true,
      passive: true,
      capture: true,
    });
  });

  // Fallback: count visitors who read without ever interacting. Fires well
  // after page quiescence, so lab tooling has stopped tracing by then.
  window.addEventListener("load", function () {
    setTimeout(loadAnalytics, 10000);
  });
    </script>
  )
}

---
import { SITE } from "../lib/constants";

interface Props {
  post: {
    id: string;
    data: { title: string; pubDate: string };
  };
  headings: { depth: number; slug: string; text: string }[];
  Content: any;
  pathname: string;
  collection: string;
}

const { post, headings, Content, pathname, collection } = Astro.props;
const githubUrl = `https://github.com/dlangk/langkilde/blob/main/src/content/${collection}/${post.id}`;
---

<nav id="sidebar">
  <a href="/">← Home</a>
  <h3>Sections</h3>
  <ul id="toc">
    {
      headings
        .filter((h) => (h.depth === 2 || h.depth === 3) && h.slug !== "footnote-label")
        .map((heading) => (
          <li class={heading.depth === 3 ? "toc-h3" : ""}>
            <a href={`#${heading.slug}`}>{heading.depth === 3 ? `› ${heading.text}` : heading.text}</a>
          </li>
        ))
    }
  </ul>
</nav>

<main>
  <article>
    <h1 class="title">{post.data.title}</h1>
    <div class="post-meta">
      <small class="pubdate">By {SITE.author}</small>
      <span class="separator">|</span>
      <small class="pubdate">{post.data.pubDate}</small>
      <span class="separator">|</span>
      <a href={pathname} class="permalink">Permalink</a>
      <span class="separator">|</span>
      <a href={githubUrl} class="permalink" target="_blank" rel="noopener">GitHub</a>
    </div>

    <div class="post-content">
      <Content />
    </div>
  </article>
</main>

<script src="../scripts/tooltips.ts"></script>

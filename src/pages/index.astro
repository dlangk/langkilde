---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { sortByDate } from "../lib/utils";
import { PATHS } from "../lib/constants";

const shortPosts = sortByDate(
  (await getCollection("short")).filter(
    (post) => !post.data.draft || import.meta.env.DEV
  )
);
---

<BaseLayout title="Home">
  <nav id="sidebar" class="landing-sidebar">
    <h1>Daniel Langkilde</h1>
    <ul id="toc">
      <li><a href="/about">About</a></li>
      <li><a href="#writings">Writings</a></li>
      <li><a href="/investments">Investments</a></li>
      <li><a href="/memes">Memes</a></li>
      <li><a href="/yatzy/" target="_blank" rel="noopener">Yatzy</a></li>
      <link
        rel="alternate"
        type="application/rss+xml"
        href="/rss.xml"
        title="RSS Feed"
      />
    </ul>
    <div id="post-preview" class="sidebar-preview" aria-live="polite"></div>
  </nav>

  <main>
    <!-- Writings Section -->
    <section id="writings" class="post-list">
      <h1>Writings</h1>
      <ul>
        {
          shortPosts.map((post) => (
            <li>
              <a href={`${PATHS.short}/${post.id}`} data-preview={post.data.description}>
                {post.data.title} <small>({post.data.pubDate})</small>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    <div class="bottom-spacer"></div>
  </main>
</BaseLayout>

<script src="../scripts/tooltips.ts"></script>

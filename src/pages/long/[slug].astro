---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostPage from "../../components/PostPage.astro";
import { render } from "astro:content";

export async function getStaticPaths() {
  // Long writings are unfinished and intentionally not published.
  // The content stays in src/content/long/ but no pages are built.
  // To republish: return posts.map((post) => ({ params: { slug: post.id }, props: { post } }))
  return [];
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BaseLayout title={post.data.title} image={post.data.image} description={post.data.description}>
  <PostPage
    post={post}
    headings={headings}
    Content={Content}
    pathname={Astro.url.pathname}
  />
</BaseLayout>

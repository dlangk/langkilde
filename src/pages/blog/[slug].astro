---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostPage from "../../components/PostPage.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("short");
  return posts
    // Drafts are viewable in `astro dev` but excluded from production builds.
    .filter((post) => !post.data.draft || import.meta.env.DEV)
    .map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BaseLayout title={post.data.title} image={post.data.image} description={post.data.description}>
  <PostPage
    post={post}
    headings={headings}
    Content={Content}
    pathname={Astro.url.pathname}
  />
</BaseLayout>
